# RCS environment — copy to .env at the repo root and adjust.
# apps/api and packages/rcs-cli load this file automatically (shell vars win).
# apps/web reads its own apps/web/.env.local (see apps/web/.env.local.example).

# ── API (apps/api) ───────────────────────────────────────────────────────────
PORT=4000
# Public base URL of the API (magic links, boot log)
RCS_API_BASE_URL=http://localhost:4000
# Browser origins allowed by CORS — comma-separated for multiple
RCS_WEB_ORIGIN=http://localhost:3000

# Secret shared by the API and RCS-CLI for JWT signing/verification.
# REQUIRED in production. Generate one: openssl rand -hex 32
RCS_JWT_SECRET=rcs-dev-secret-change-me

# Seeded Admin account (password must be EXACTLY 16 characters).
# Leave RCS_ADMIN_PASSWORD unset to have a fresh one generated and printed at boot.
RCS_ADMIN_EMAIL=admin@risecore.studio
#RCS_ADMIN_PASSWORD=

# Seed demo tickets at boot (dev only; default off — no dummy data)
#RCS_SEED_DEMO=true

# ── Storage ──────────────────────────────────────────────────────────────────
# Redis: OTP store (strict 5-min TTL) + future real-time pub/sub & caching.
# Unset = in-memory dev fallback with the same TTL.
#REDIS_URL=redis://localhost:6379

# PostgreSQL: entity storage (users, tickets, logs).
# Unset = in-memory dev fallback.
#DATABASE_URL=postgres://rcs:rcs@localhost:5432/rcs

# ── RCS-CLI local bridge (packages/rcs-cli) ─────────────────────────────────
RCS_BRIDGE_PORT=3711
# The local working copy the Workspace explorer browses (your GitHub clone).
# Default: the directory the daemon is started in.
#RCS_WORKSPACE_DIR=/path/to/your/cloned/repo
