# apps/web environment — copy to apps/web/.env.local
# NEXT_PUBLIC_* values are baked in at BUILD time.

# Base URL of the RCS API
NEXT_PUBLIC_RCS_API=http://localhost:4000

# Base URL of the auth subdomain (defaults to NEXT_PUBLIC_RCS_API + /auth)
#NEXT_PUBLIC_RCS_AUTH=https://auth.risecorestudio.com

# Apex domain for the cross-subdomain session cookie.
# Leave unset in development (the cookie then stays host-only).
#NEXT_PUBLIC_RCS_COOKIE_DOMAIN=risecorestudio.com

# WebSocket URL of the local RCS-CLI bridge daemon
NEXT_PUBLIC_RCS_BRIDGE=ws://localhost:3711
